<div class="custom-announcement-bar" style="background-color: {{ section.settings.bg_color }};">
  <div class="custom-announcement-bar__track">
    {% for i in (1..3) %}
      <span class="custom-announcement-bar__text" style="color: {{ section.settings.text_color }};">
        {{ section.settings.announcement_text }}
      </span>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Custom Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "FREE SHIPPING ON ORDERS OVER PKR 3,000"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#C98A93"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed (seconds)",
      "min": 5,
      "max": 40,
      "step": 1,
      "default": 14
    },
    {
      "type": "checkbox",
      "id": "enable_scroll",
      "label": "Enable right-to-left scrolling",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Custom Announcement Bar"
    }
  ]
}
{% endschema %}

<style>
  .custom-announcement-bar {
    width: 100%;
    overflow: hidden;
    padding: 8px 0;
  }
  .custom-announcement-bar__track {
    display: {% if section.settings.enable_scroll %}inline-flex{% else %}flex{% endif %};
    {% if section.settings.enable_scroll %}
    animation: custom-marquee {{ section.settings.scroll_speed }}s linear infinite;
    {% else %}
    justify-content: center;
    {% endif %}
    white-space: nowrap;
  }
  .custom-announcement-bar__text {
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0 40px;
    font-family: 'Jost', sans-serif;
  }
  @keyframes custom-marquee {
    0%   { transform: translateX(0%); }
    100% { transform: translateX(-33.333%); }
  }
</style>
